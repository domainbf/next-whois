# Redis (required for custom WHOIS server persistence on serverless platforms)
# Option 1: Connection URL (Upstash, Vercel KV, Railway, etc.)
REDIS_URL=redis://localhost:6379

# Option 2: Host/Port/Password (self-hosted Redis)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# Cache TTL in seconds (default: 3600 = 1 hour)
REDIS_CACHE_TTL=3600

# WHOIS query timeout in milliseconds
# Vercel Hobby plan has a 10s function limit — keep this under 8000
# Vercel Pro plan allows up to 300s — can safely use 15000
WHOIS_TIMEOUT_MS=10000

# Moz API (optional — for domain authority metrics)
# MOZ_ACCESS_ID=
# MOZ_SECRET_KEY=

# Admin API secret (optional — protects /api/admin/tld-servers)
# ADMIN_SECRET=

# Max WHOIS follow redirects (0 = minimal, improves speed on serverless)
NEXT_PUBLIC_MAX_WHOIS_FOLLOW=0

# Max query history items stored in browser (-1 = unlimited)
NEXT_PUBLIC_HISTORY_LIMIT=-1
