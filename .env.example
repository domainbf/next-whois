# ─────────────────────────────────────────────
# Database (required)
# ─────────────────────────────────────────────
# Supabase / Neon / PlanetScale PostgreSQL connection string
POSTGRES_URL=postgresql://user:password@host:5432/dbname?sslmode=require
# Direct (non-pooling) connection — used for migrations
POSTGRES_URL_NON_POOLING=postgresql://user:password@host:5432/dbname

# ─────────────────────────────────────────────
# NextAuth (required)
# ─────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-here
# Your production URL (must match your Vercel domain)
NEXTAUTH_URL=https://your-app.vercel.app

# ─────────────────────────────────────────────
# Email — Resend (required for welcome, reset, reminder emails)
# ─────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Must match a verified domain on resend.com/domains
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ─────────────────────────────────────────────
# Site Base URL (recommended)
# ─────────────────────────────────────────────
# Used in email links (password reset, subscription cancel, etc.)
# If not set, falls back to NEXTAUTH_URL
NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app

# ─────────────────────────────────────────────
# Cron Security (recommended for production)
# ─────────────────────────────────────────────
# Protects /api/remind/process and /api/cron/ping from unauthorized calls
# Vercel automatically sends this as: Authorization: Bearer <CRON_SECRET>
# Generate with: openssl rand -hex 32
CRON_SECRET=your-random-cron-secret

# ─────────────────────────────────────────────
# WHOIS / RDAP Settings
# ─────────────────────────────────────────────
# Query timeout in milliseconds (Vercel Hobby: keep under 8000; Pro: up to 15000)
WHOIS_TIMEOUT_MS=10000
# Max WHOIS redirect follows (0 = minimal, better for serverless)
NEXT_PUBLIC_MAX_WHOIS_FOLLOW=0
# Max query history items stored (-1 = unlimited)
NEXT_PUBLIC_HISTORY_LIMIT=-1

# ─────────────────────────────────────────────
# Optional — Redis (for custom WHOIS server persistence)
# ─────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379
# REDIS_CACHE_TTL=3600

# ─────────────────────────────────────────────
# Optional — Moz API (domain authority metrics)
# ─────────────────────────────────────────────
# MOZ_ACCESS_ID=
# MOZ_SECRET_KEY=
