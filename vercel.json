{
  "framework": "nextjs",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "functions": {
    "src/pages/api/lookup.ts": {
      "maxDuration": 30
    },
    "src/pages/api/whois-servers.ts": {
      "maxDuration": 10
    },
    "src/pages/api/admin/tld-servers.ts": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
